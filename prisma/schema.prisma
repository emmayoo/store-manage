// Schedule SaaS DB Schema (MVP)
// 시간: minute-of-day (0~1440), 타임존: 지점 로컬(branches.timezone)
// 모든 id: 숫자 시퀀스(SERIAL). userId = User.id (불변). 로그인 = username(아이디), phone은 변경 가능.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------
// Enums
// ----------------------------------------

enum BranchRole {
  OWNER
  MANAGER
  STAFF
}

enum ScheduleHistoryActionType {
  CREATE
  UPDATE
  DELETE
}

// ----------------------------------------
// Users (userId = id. 로그인 = username(아이디), phone은 변경 가능한 연락처)
// ----------------------------------------

model User {
  id           Int       @id @default(autoincrement())
  name         String
  username     String    @unique // 로그인용 아이디 (불변 식별자)
  phone        String    // 연락처, 변경 가능
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  employments       Employment[]
  templateItems    TemplateItem[]
  schedules        Schedule[]         @relation("ScheduleUser")
  schedulesCreated Schedule[]         @relation("ScheduleCreatedBy")
  dayOffs          DayOff[]
  scheduleHistories ScheduleHistory[]
  branchInvites    BranchInvite[]     @relation("BranchInviteCreatedBy")
}

// ----------------------------------------
// Branches (지점, timezone 보유)
// ----------------------------------------

model Branch {
  id        Int       @id @default(autoincrement())
  name      String
  location  String?   // 위치 (주소/설명). 추후 지도 연동 예정
  phone     String?   // 지점 연락처
  thumbnail String?   // 썸네일 이미지 URL (추후 업로드)
  timezone  String
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime?  @map("deleted_at")

  employments Employment[]
  templates   Template[]
  schedules   Schedule[]
  dayOffs     DayOff[]
  invites     BranchInvite[]
}

// ----------------------------------------
// Employments (지점별 소속 + 역할)
// ----------------------------------------

model Employment {
  id         Int          @id @default(autoincrement())
  userId     Int          @map("user_id")
  branchId   Int          @map("branch_id")
  role       BranchRole
  hireDate   DateTime     @map("hire_date")
  resignDate DateTime?    @map("resign_date")
  color      String?      @map("color")
  deletedAt  DateTime?    @map("deleted_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
  @@index([userId])
}

// ----------------------------------------
// Templates
// ----------------------------------------

model Template {
  id        Int       @id @default(autoincrement())
  branchId  Int       @map("branch_id")
  name      String
  createdBy Int       @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  branch Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items  TemplateItem[]
}

// ----------------------------------------
// Template Items
// ----------------------------------------

model TemplateItem {
  id          Int    @id @default(autoincrement())
  templateId  Int    @map("template_id")
  userId      Int    @map("user_id")
  weekday     Int
  startMinute Int    @map("start_minute")
  endMinute   Int    @map("end_minute")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([templateId, userId, weekday])
  @@index([templateId])
}

// ----------------------------------------
// Schedules
// ----------------------------------------

model Schedule {
  id          Int       @id @default(autoincrement())
  branchId    Int       @map("branch_id")
  userId      Int       @map("user_id")
  date        DateTime  @db.Date
  startMinute Int       @map("start_minute")
  endMinute   Int       @map("end_minute")
  createdBy   Int       @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  branch        Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user          User              @relation("ScheduleUser", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser User              @relation("ScheduleCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  histories     ScheduleHistory[]

  @@index([branchId, date, deletedAt])
  @@index([userId, date, deletedAt])
  @@index([date])
}

// ----------------------------------------
// Day Offs
// ----------------------------------------

model DayOff {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  branchId  Int       @map("branch_id")
  date      DateTime  @db.Date
  reason    String?
  createdAt DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([branchId, date])
}

// ----------------------------------------
// Schedule Histories
// ----------------------------------------

model ScheduleHistory {
  id         Int                      @id @default(autoincrement())
  scheduleId Int                      @map("schedule_id")
  actionType ScheduleHistoryActionType @map("action_type")
  changedBy  Int                      @map("changed_by")
  asIs       String?                  @map("as_is")
  toBe       String?                  @map("to_be")
  createdAt  DateTime                 @default(now()) @map("created_at")

  schedule      Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  changedByUser User     @relation(fields: [changedBy], references: [id], onDelete: Restrict)

  @@index([scheduleId])
  @@index([createdAt])
}

// ----------------------------------------
// Branch Invites (지점 초대 링크)
// ----------------------------------------

model BranchInvite {
  id         Int       @id @default(autoincrement())
  branchId   Int       @map("branch_id")
  token      String    @unique // 초대 토큰 (URL 파라미터)
  expiresAt  DateTime  @map("expires_at")
  createdBy  Int       @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  acceptedAt DateTime? @map("accepted_at")
  deletedAt  DateTime? @map("deleted_at")

  branch  Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  creator User   @relation("BranchInviteCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([token])
}
